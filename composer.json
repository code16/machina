{
    "name": "code16/machina",
    "description": "Machine to machine authentication for Laravel",
    "require": {
        "php": "8.3.*|8.4.*|8.5.*",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "php-open-source-saver/jwt-auth": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "orchestra/testbench": "8.*|9.*|10.*|11.*"
    },
    "autoload": {
       "psr-4": {
            "Code16\\Machina\\": "src/Machina"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Code16\\Machina\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Code16\\Machina\\MachinaServiceProvider"
            ]
        }
    },
    "license": "MIT"
}
